# --- Configuración de Base de Datos ---
DB_CONTAINER_NAME=procesally_db
POSTGRES_USER=procesally_user
POSTGRES_PASSWORD=tu_password_seguro_aqui
POSTGRES_DB=procesally
DB_PORT=5432
DB_VOLUME_NAME=procesally_pgdata

# Host de la BD: 
# - 'db' si usas Docker Compose (nombre del servicio)
# - 'localhost' si corres la app nativamente con python
DB_HOST=db

# --- Configuración de CORS ---
# Ejemplo: ["http://localhost:3000", "https://tu-app.com"]
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_EXPOSE_HEADERS=["*"]
CORS_MAX_AGE=600

# --- Configuración de Docker (API) ---
API_BUILD_CONTEXT=.
API_CONTAINER_NAME=procesally_api
API_PORT=8000
API_BIND_MOUNT=./app

# --- Modo de Ejecución ---
# Agrega '--reload' para desarrollo local (hot-reload)
# Déjalo vacío para producción
FASTAPI_MODE=--reload

# --- Logging ---
# Niveles: INFO, DEBUG, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
